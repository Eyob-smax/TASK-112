[mysqld]
# Meridian MySQL 8.0 Configuration

# Character set — always utf8mb4 for full Unicode support
character-set-server    = utf8mb4
collation-server        = utf8mb4_unicode_ci
character-set-filesystem = utf8mb4

# InnoDB settings for reliability
default-storage-engine  = InnoDB
innodb_strict_mode      = ON
innodb_file_per_table   = ON

# Connection and timeout settings (single-host deployment — 50 is ample)
max_connections         = 50
wait_timeout            = 300
interactive_timeout     = 300
connect_timeout         = 10

# Cap InnoDB buffer pool for constrained environments (CI / single-host)
innodb_buffer_pool_size = 128M

# Strict SQL mode — prevents silent truncation and implicit conversions
sql_mode               = STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

# Binary logging for point-in-time recovery (complements daily backups)
# log_bin                = /var/lib/mysql/meridian-binlog
# binlog_expire_logs_seconds = 604800

# Slow query log for performance troubleshooting
slow_query_log          = ON
slow_query_log_file     = /var/lib/mysql/slow.log
long_query_time         = 1

# UUID primary keys require full row-based replication if ever enabled
binlog_format           = ROW
