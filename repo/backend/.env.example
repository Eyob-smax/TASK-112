APP_NAME="Meridian"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

# LAN base URL used for generating attachment share links.
# Set this to the LAN-accessible IP or hostname of this server.
# Example: http://192.168.1.100:8000
LAN_BASE_URL=http://192.168.1.100:8000

LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=meridian
DB_USERNAME=meridian
DB_PASSWORD=change_me_in_production

# MySQL root password — used by docker-compose to initialize the MySQL
# container. Keep separate from DB_PASSWORD (the application user password).
MYSQL_ROOT_PASSWORD=change_this_root_password_in_production

# Queue driver — must remain 'database' for offline single-host operation
QUEUE_CONNECTION=database
QUEUE_FAILED_DRIVER=database-uuids

# Filesystem — must remain 'local' for offline single-host operation
FILESYSTEM_DISK=local

# Separate encryption key for attachment payloads (AES-256-CBC)
# Generate with: php -r "echo base64_encode(random_bytes(32));"
ATTACHMENT_ENCRYPTION_KEY=

# Attachment constraints
ATTACHMENT_MAX_SIZE_MB=25
ATTACHMENT_MAX_FILES_PER_RECORD=20
ATTACHMENT_VALIDITY_DAYS=365

# LAN link sharing
LINK_MAX_TTL_HOURS=72

# Configuration canary rollout
CANARY_MAX_PERCENT=10
CANARY_MIN_PROMOTION_HOURS=24
# Set to the actual count of eligible store targets in this deployment (must be > 0).
# Used as the server-authoritative denominator for the 10% canary cap on store rollouts.
CANARY_STORE_COUNT=1
# Comma-separated UUID list of eligible store targets.
# Store-level rollout target_ids must be a subset of this list.
CANARY_STORE_IDS=

# Backup and retention
BACKUP_RETENTION_DAYS=14
METRICS_RETENTION_DAYS=90
LOG_RETENTION_DAYS=90
BACKUP_SCHEDULE_TIME="02:00"

# Workflow SLA defaults
WORKFLOW_SLA_BUSINESS_DAYS=2

# Sales restock fee defaults
RESTOCK_FEE_DEFAULT_PERCENT=10
RESTOCK_FEE_QUALIFYING_DAYS=30

# Authentication lockout
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# Session driver — not used (Sanctum token-based auth)
SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=file
CACHE_PREFIX=meridian

MAIL_MAILER=log
